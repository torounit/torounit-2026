                0
              ],
              "children": [
                {
                  "type": "text",
                  "id": "ViKPz",
                  "name": "Paragraph 1",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "WordPress 6.9 では、ブロックテーマ開発に関するいくつかの重要な新機能が導入されました。この記事では、その中でも特に注目すべき変更点について詳しく解説します。",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-medium",
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "czJrh",
                  "name": "Heading 2",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "theme.json の新しい設定項目",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-xl",
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "mUsc3",
                  "name": "Paragraph 2",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "theme.json のバージョン3では、新しい設定項目がいくつか追加されています。特に typography セクションの拡張により、より柔軟なフォント設定が可能になりました。フォントファミリーの定義方法が改善され、Google Fonts との統合もよりシームレスになっています。",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-medium",
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "VqGlS",
                  "name": "Heading 2 - 2",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "スペーシングシステムの改善",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-xl",
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Z720a",
                  "name": "Paragraph 3",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "spacing セクションでは、デフォルトのスペーシングサイズを無効化し、独自のサイズスケールを定義できるようになりました。フィボナッチ数列に基づいたスペーシングスケールを使用することで、一貫性のあるリズムを作り出すことができます。",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-medium",
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "A7qzL",
                  "name": "Code Block",
                  "width": "fill_container",
                  "fill": "$--color-smoke",
                  "cornerRadius": 4,
                  "layout": "vertical",
                  "padding": "$--spacing-xsmall",
                  "children": [
                    {
                      "type": "text",
                      "id": "NobHH",
                      "name": "Code Text",
                      "fill": "$--color-contrast",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "\"spacingSizes\": [\n  { \"name\": \"Tiny\", \"size\": \"0.5rem\", \"slug\": \"20\" },\n  { \"name\": \"Small\", \"size\": \"1.5rem\", \"slug\": \"40\" },\n  { \"name\": \"Medium\", \"size\": \"2.5rem\", \"slug\": \"50\" },\n  { \"name\": \"Large\", \"size\": \"4rem\", \"slug\": \"60\" }\n]",
                      "lineHeight": 2,
                      "fontFamily": "M Plus 1 Code",
                      "fontSize": 14,
                      "fontWeight": "200"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "frB3Q",
                  "name": "Paragraph 4",
                  "fill": "$--color-contrast",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "これらの新機能を活用することで、より洗練されたブロックテーマを構築できるようになります。特に theme.json を中心としたデザインシステムの構築が、WordPress のエコシステムにおいてますます重要になってきています。",
                  "lineHeight": 1.75,
                  "fontFamily": "Zen Kaku Gothic New",
                  "fontSize": "$--font-size-medium",
                  "fontWeight": "normal"
